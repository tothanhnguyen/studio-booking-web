# PostgreSQL runtime connection (use Supabase pooler in hosted environments)
DATABASE_URL=postgresql://postgres:postgres@localhost:54329/mowstudio_test

# PostgreSQL direct connection used by Prisma migrations
DIRECT_URL=postgresql://postgres:postgres@localhost:54329/mowstudio_test

# Supabase public browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Server-only Supabase key; never expose with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Canonical application origin
APP_URL=http://localhost:3000

# SePay / VietQR payment
SEPAY_BANK_BIN=970422
SEPAY_BANK_ACCOUNT=0123456789
SEPAY_ACCOUNT_NAME=Mow Studio
SEPAY_TRANSFER_PREFIX=BOOKING:
# Optional in local test; when set, webhook must include x-sepay-signature HMAC-SHA256
SEPAY_WEBHOOK_SECRET=

# Resend email provider
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=no-reply@mowstudio.local

# Sentry observability (optional; disabled when SENTRY_DSN is empty)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Build-time source map upload (CI only; never commit real values)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Release correlation SHA (set by CI/Vercel at build time)
NEXT_PUBLIC_RELEASE_SHA=

# Admin seed (chỉ dùng cho scripts/seed-admin.ts; KHÔNG commit giá trị thật)
ADMIN_EMAIL=admin@mowstudio.local
ADMIN_PASSWORD=
